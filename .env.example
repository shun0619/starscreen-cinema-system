# StarScreen Cinemas - local database settings
#
# Setup:  copy this file, rename the copy to ".env", edit the values.
# Never commit .env (it is gitignored). Without a valid .env the app
# simply runs on the in-memory sample data.

# true = use SQL Server (after running database/schema.sql)
DB_ENABLED=false

# Same value as the "Server name" box in SSMS, e.g.:
#   DESKTOP-J6CASQ8         (default instance = your PC name)
#   localhost\SQLEXPRESS    (SQL Server Express)
DB_SERVER=localhost

DB_NAME=StarScreenCinema

# Leave empty to auto-detect the installed ODBC driver
DB_DRIVER=

# yes = Windows Authentication (like SSMS, no user/password needed).
# For a SQL Server login: set no and fill in DB_USER / DB_PASSWORD.
DB_TRUSTED=yes
DB_USER=
DB_PASSWORD=
